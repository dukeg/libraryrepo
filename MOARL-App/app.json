{
  "expo": {
    "name": "MOARL — World Library",
    "slug": "moarl-world-library",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#06060a",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06060a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moarl.worldlibrary",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for scanning book barcodes",
        "NSPhotoLibraryUsageDescription": "Used for profile picture"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#06060a"
      },
      "package": "com.moarl.worldlibrary",
      "versionCode": 1,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "minSdkVersion": 24,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.DOWNLOAD_WITHOUT_NOTIFICATION",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "moarl" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./src/assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/notification-icon.png",
          "color": "#c9a84c",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#06060a",
          "image": "./src/assets/splash.png",
          "imageWidth": 200
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "moarl-world-library-2025"
      }
    },
    "owner": "moarl",
    "description": "MOARL — Mother of All Real-Time Libraries. Access 50M+ free e-books, journals and manuscripts from 247 world libraries, powered by DeepSeek AI.",
    "githubUrl": "https://github.com/moarl/world-library-app",
    "primaryColor": "#c9a84c",
    "keywords": ["library", "ebooks", "books", "reading", "AI", "free books", "world library"]
  }
}
